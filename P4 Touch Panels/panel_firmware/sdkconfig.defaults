# Waveshare round P4 boards using component waveshare/esp32_p4_wifi6_touch_lcd_4b (4B / 3.4C / 4C family).
# Pick LCD type below to match the physical panel: 800×800 3.4" vs 720×720 4" (Waveshare labels the latter "4C" on the 3.4C product page).
# Wiki: https://www.waveshare.com/wiki/ESP32-P4-WIFI6-Touch-LCD-4B · https://www.waveshare.com/wiki/ESP32-P4-WIFI6-Touch-LCD-3.4C
#
# Wi-Fi is on the C6 via esp_hosted (SDIO) + esp_wifi_remote — do not enable native P4 host Wi-Fi.

# --- Flash / partition / OTA rollback (see partitions.csv) ---
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000
# App rollback follows bootloader option on IDF 5.4+ (no separate CONFIG_APP_ROLLBACK_ENABLE).
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# --- PSRAM (MIPI-DPI / LVGL buffers use SPIRAM) ---
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_HEX=y
CONFIG_SPIRAM_SPEED_200M=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768

# --- Native Wi-Fi on P4 host (mutually exclusive with esp_wifi_remote) ---
# CONFIG_ESP_HOST_WIFI_ENABLED is not set

# --- ESP-Hosted: Espressif "ESP32-P4 Function EV" SDIO preset (matches Waveshare routing per README) ---
CONFIG_ESP_HOSTED_ENABLED=y
CONFIG_ESP_HOSTED_CP_TARGET_ESP32C6=y
CONFIG_ESP_HOSTED_PRIV_ENABLE_WIFI_OPTIONS=y
CONFIG_ESP_HOSTED_IDF_SLAVE_TARGET="esp32c6"
CONFIG_ESP_HOSTED_P4_DEV_BOARD_FUNC_BOARD=y
CONFIG_ESP_HOSTED_SDIO_HOST_INTERFACE=y
CONFIG_ESP_HOSTED_SDIO_RESET_ACTIVE_HIGH=y
CONFIG_ESP_HOSTED_SDIO_OPTIMIZATION_RX_STREAMING_MODE=y
CONFIG_ESP_HOSTED_SDIO_SLOT_1=y
CONFIG_ESP_HOSTED_SDIO_4_BIT_BUS=y
CONFIG_ESP_HOSTED_SDIO_BUS_WIDTH=4
CONFIG_ESP_HOSTED_SDIO_CLOCK_FREQ_KHZ=40000
CONFIG_ESP_HOSTED_SDIO_TX_Q_SIZE=20
CONFIG_ESP_HOSTED_SDIO_RX_Q_SIZE=20
CONFIG_ESP_HOSTED_SDIO_RESET_DELAY_MS=1500
CONFIG_ESP_HOSTED_SLAVE_RESET_ON_EVERY_HOST_BOOTUP=y
CONFIG_ESP_HOSTED_GPIO_SLAVE_RESET_SLAVE=54
CONFIG_ESP_HOSTED_TRANSPORT_RESTART_ON_FAILURE=y
CONFIG_ESP_HOSTED_MEM_MONITOR=y
CONFIG_ESP_HOSTED_ENABLE_ITWT=y
CONFIG_ESP_HOSTED_USE_MEMPOOL=y
CONFIG_ESP_HOSTED_MAX_SIMULTANEOUS_SYNC_RPC_REQUESTS=5
CONFIG_ESP_HOSTED_MAX_SIMULTANEOUS_ASYNC_RPC_REQUESTS=5
CONFIG_ESP_HOSTED_HOST_TO_ESP_WIFI_DATA_THROTTLE=y
CONFIG_ESP_HOSTED_PRIV_WIFI_TX_SDIO_HIGH_THRESHOLD=80
CONFIG_ESP_HOSTED_TO_WIFI_DATA_THROTTLE_HIGH_THRESHOLD=80
CONFIG_ESP_HOSTED_TO_WIFI_DATA_THROTTLE_LOW_THRESHOLD=60
CONFIG_ESP_HOSTED_ENABLE_PEER_DATA_TRANSFER=y
CONFIG_ESP_HOSTED_MAX_CUSTOM_MSG_HANDLERS=3

CONFIG_ESP_WIFI_REMOTE_ENABLED=y
CONFIG_ESP_WIFI_REMOTE_LIBRARY_HOSTED=y

# --- BSP: 720x720 4" (not 800x800 3.4") ---
# Two DPI framebuffers + avoid-tear + full refresh: LVGL renders into panel VRAM (esp_lvgl_port); partial+single-FB can stay black on P4 DSI.
CONFIG_BSP_LCD_DPI_BUFFER_NUMS=2
CONFIG_BSP_DISPLAY_LVGL_AVOID_TEAR=y
CONFIG_BSP_DISPLAY_LVGL_FULL_REFRESH=y
# CONFIG_BSP_DISPLAY_LVGL_DIRECT_MODE is not set
CONFIG_BSP_LCD_COLOR_FORMAT_RGB888=y
CONFIG_BSP_LCD_TYPE_720_720_4_INCH=y

# --- Stacks: Lottie runs after lv_async_call; keep headroom on main if defaults merge here ---
CONFIG_ESP_MAIN_TASK_STACK_SIZE=32768
# PSRAM stacks: on IDF 5.4+ this implies external stack allocation where supported.
CONFIG_FREERTOS_TASK_CREATE_ALLOW_EXT_MEM=y

# --- TLS: LAN / self-signed devices (e.g. Reolink); treat OTA URLs as trusted inputs ---
CONFIG_ESP_TLS_INSECURE=y
CONFIG_ESP_TLS_SKIP_SERVER_CERT_VERIFY=y

# --- LVGL: ThorVG + Lottie + gestures (see README) ---
CONFIG_LV_CONF_SKIP=y
CONFIG_LV_COLOR_DEPTH_24=y
CONFIG_LV_DEF_REFR_PERIOD=33
CONFIG_LV_USE_DRAW_SW=y
CONFIG_LV_USE_VECTOR_GRAPHIC=y
CONFIG_LV_USE_THORVG=y
CONFIG_LV_USE_THORVG_INTERNAL=y
CONFIG_LV_USE_LOTTIE=y
CONFIG_LV_USE_FLOAT=y
CONFIG_LV_USE_MATRIX=y
CONFIG_LV_USE_GESTURE_RECOGNITION=y
CONFIG_LV_FONT_MONTSERRAT_24=y

CONFIG_IDF_EXPERIMENTAL_FEATURES=y

# LCD debug: set both to 0 for normal boot after display works.
CONFIG_SCREEN_TEST_LCD_DSI_PATTERN_BOOT_MS=0
CONFIG_SCREEN_TEST_LCD_SOLID_RED_BOOT_MS=0
