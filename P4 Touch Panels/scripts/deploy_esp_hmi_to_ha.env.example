# Copy this file to deploy_esp_hmi_to_ha.env (same directory) and set your values.
#   cp scripts/deploy_esp_hmi_to_ha.env.example scripts/deploy_esp_hmi_to_ha.env
# deploy_esp_hmi_to_ha.env is gitignored — do not commit real passwords.
#
# The deploy script loads that file automatically (set -a; source; set +a).
# Override path: DEPLOY_ENV_FILE=/path/to/other.env ./scripts/deploy_esp_hmi_to_ha.sh
#
# Quote passwords that contain &, #, spaces, etc. (single quotes are safest).

SMB_USER=homeassistant
SMB_PASSWORD='change_me'

# Optional (defaults shown):
# SMB_HOST=192.168.1.2
# SMB_SHARE=config

# Optional: only if you use ./scripts/deploy_esp_hmi_to_ha.sh --restart (SSH):
# HA_SSH_USER=root
# HA_SSH_PORT=22
# HA_SSH_PASSWORD='your_ssh_password_if_needed'
